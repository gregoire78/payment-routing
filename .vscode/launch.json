    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "PaymentRoutingApplication",
            "request": "launch",
            "mainClass": "com.bank.paymentrouting.PaymentRoutingApplication",
            "projectName": "backend"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/frontend/src/app/features/messages-screen/messages-screen.ts",
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ]
        }
    ]
}